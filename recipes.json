    "servings": "creami tub",
    "ingredients": [
      "1 cup 2% + milk",
      "1 tbsp cream cheese (optional — makes the ice cream thicker)",
      "1/4 cup heavy cream",
      "1/4 cup granulated sugar"
    ],
    "instructions": [
      "Mix all ingredients together in a pint tub and freeze 24 hours",
      "Once frozen, spin on the ice cream setting.",
      "The ice cream will come out slightly crumbly — add 1 tbsp milk and respin."
